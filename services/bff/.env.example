PORT=3000

# Upstream Java services
OFFER_SERVICE_URL=http://localhost:8081
PARTNER_SERVICE_URL=http://localhost:8082
ELIGIBILITY_SERVICE_URL=http://localhost:8083
REDEMPTION_SERVICE_URL=http://localhost:8084

# PostgreSQL (same cc-postgres Docker container used by Java services)
DATABASE_URL=postgresql://commerce:commerce_dev@localhost:5432/connected_commerce

# JWT — change this to a long random string in production
JWT_SECRET=cc-dev-secret-change-in-prod

# AI for personalised recommendations — set ONE (leave others blank)
# Keys auto-detected: sk-ant-… = Claude · sk-… = OpenAI · AIza… = Gemini
GEMINI_API_KEY=        # free tier: https://aistudio.google.com/app/apikey
OPENAI_API_KEY=        # https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=     # https://console.anthropic.com/settings/keys
